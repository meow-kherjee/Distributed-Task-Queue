// This is where i'll be defining the schemas

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  SUCCESSFUL
  FAILED
}

model Task {
  taskId String     @id @db.Uuid // String -> prisma type, @id -> primary key, @db.Uuid -> db will have uuid as col. type
  status TaskStatus // it will get either of the values defined using enum
}

model Todo {
  taskId     String @id @db.Uuid
  retryCount Int    @db.Integer
  maxRetry   Int    @db.Integer
  payload    Json   @db.Json
}
